{
  "name": "renderline",
  "version": "0.8.0",
  "description": "Midjourney A/B/C/D QC and independent Browser panes for Hermes Desktop",
  "type": "module",
  "bin": {
    "renderline": "scripts/install.mjs"
  },
  "files": [
    "plugin.js",
    "manifest.json",
    "skill/",
    "dashboard/manifest.json",
    "dashboard/plugin_api.py",
    "sidecar/__init__.py",
    "sidecar/app.py",
    "sidecar/requirements.txt",
    "sidecar/schema.json",
    "backend/__init__.py",
    "backend/plugin.yaml",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --check plugin.js && node --check scripts/sidecar.mjs && node --test --test-concurrency=1 tests/*.test.mjs",
    "sidecar:install": "node scripts/sidecar.mjs install",
    "sidecar:verify": "node scripts/sidecar.mjs verify",
    "fixture:e2e": "node scripts/fixture-e2e.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeiTuz/Renderline.git"
  },
  "bugs": {
    "url": "https://github.com/HeiTuz/Renderline/issues"
  },
  "homepage": "https://github.com/HeiTuz/Renderline#readme",
  "keywords": [
    "hermes-agent",
    "hermes-desktop",
    "browser",
    "quality-control",
    "midjourney",
    "plugin"
  ],
  "author": "HeiTuz",
  "license": "MIT"
}
